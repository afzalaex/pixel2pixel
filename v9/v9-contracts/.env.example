# Sepolia RPC endpoint
SEPOLIA_RPC=https://sepolia.infura.io/v3/YOUR_KEY

# Burner deployer private key (0x...)
PRIVATE_KEY=0xYOUR_BURNER_PRIVATE_KEY

# Mnemonic used to derive rehearsal wallets m/44'/60'/0'/0/i
REHEARSAL_MNEMONIC=your twelve or twenty four word burner mnemonic here

# Low-balance rehearsal mode (recommended for <= 0.1 Sepolia ETH)
LOW_BALANCE_MODE=true
REHEARSAL_WALLET_COUNT=100
BID_INCREMENT_ETH=0.00001
AUCTION_DURATION_SECONDS=60
MAX_GAS_PRICE_GWEI=3
TX_GAS_SAFETY_BPS=14000
TX_GAS_FLAT_BUFFER_ETH=0.00002
WITHDRAW_REFUNDS=false

# Legacy prefund mode (set LOW_BALANCE_MODE=false, then use this)
# FUND_PER_WALLET_ETH=0.002

# Optional explicit snapshot hash override
# REHEARSAL_SNAPSHOT_HASH=0x0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
